# TaCOS 后端生产环境模板
# 复制此文件为 .env.production.local 并填入实际配置
# .env.production.local 不会被提交到版本控制

# Django 配置
SECRET_KEY=change-me-in-production-to-a-long-random-string
DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com,www.yourdomain.com
DJANGO_SETTINGS_MODULE=config.settings.production

# 开发环境使用 SQLite（默认）
# 生产环境使用 PostgreSQL
DATABASE_URL=postgres://tacos_user:your_password@localhost:5432/tacos_db

# CORS/CSRF 来源
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# JWT 令牌有效期
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# Redis 作为消息队列（如果 Redis 设置了密码，使用下面的格式）
CELERY_BROKER_URL=redis://localhost:6379/0
# 如果 Redis 有密码：
# CELERY_BROKER_URL=redis://:your_redis_password@localhost:6379/0
